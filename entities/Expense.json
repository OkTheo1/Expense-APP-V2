{
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Name or description of transaction"
    },
    "amount": {
      "type": "number",
      "description": "Amount"
    },
    "type": {
      "type": "string",
      "enum": [
        "expense",
        "income"
      ],
      "default": "expense"
    },
    "category": {
      "type": "string",
      "enum": [
        "Housing",
        "Food & Dining",
        "Transportation",
        "Entertainment",
        "Shopping",
        "Utilities",
        "Healthcare",
        "Education",
        "Personal",
        "Savings",
        "Other",
        "Salary",
        "Freelance",
        "Investment"
      ]
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "currency": {
      "type": "string",
      "default": "GBP",
      "enum": [
        "GBP",
        "USD",
        "EUR"
      ]
    },
    "notes": {
      "type": "string"
    },
    "profile": {
      "type": "string",
      "description": "Profile ID"
    }
  },
  "required": [
    "title",
    "amount",
    "type",
    "category",
    "date"
  ],
  "name": "Expense"
}
